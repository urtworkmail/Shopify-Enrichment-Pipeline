# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=mega-office-supplies.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_API_VERSION=2026-04

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Client replaces this with their own Postgres instance URL
DATABASE_URL=postgresql://user:password@localhost:5432/mega_enrichment

# ── Pipeline settings ─────────────────────────────────────────────────────────
INPUT_CSV=products_export.csv
OUTPUT_DIR=output
CONCURRENT_CLAUDE_CALLS=20
SCRAPER_ENABLED=true
SCRAPER_DELAY_SECONDS=2

# ── Tier thresholds (AUD) ─────────────────────────────────────────────────────
TIER1_MIN_PRICE=50.0
TIER2_MIN_PRICE=10.0

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
